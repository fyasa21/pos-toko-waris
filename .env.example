APP_NAME="POS Toko Waris"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_toko_waris
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@tokowaris.local"
MAIL_FROM_NAME="${APP_NAME}"

# POS Configuration
POS_STORE_NAME="Toko Waris"
POS_STORE_ADDRESS="Jl. Contoh No. 1, Tasikmalaya"
POS_STORE_PHONE="0265-xxxxxx"
POS_TAX_RATE=0
POS_LOW_STOCK_DAYS_BEFORE=7
POS_EXPIRY_DAYS_WARN=30
POS_RECEIPT_FOOTER="Terima kasih atas kunjungan Anda!"
